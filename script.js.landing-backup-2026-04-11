function initAnanNeuronBackground() {
  const canvas = document.getElementById("bg-canvas");
  if (!(canvas instanceof HTMLCanvasElement)) return () => {};

  const renderer = new THREE.WebGLRenderer({
    canvas,
    antialias: false,
