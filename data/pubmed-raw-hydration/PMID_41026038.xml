d><Keyword MajorTopicYN="N">DXA</Keyword><Keyword MajorTopicYN="N">body composition</Keyword><Keyword MajorTopicYN="N">segmental LBM</Keyword></KeywordList></MedlineCitation><PubmedData><History><PubMedPubDate PubStatus="medline"><Year>2025</Year><Month>9</Month><Day>30</Day><Hour>14</Hour><Minute>18</Minute></PubMedPubDate><PubMedPubDate PubStatus="pubmed"><Year>2025</Year><Month>9</Month><Day>30</Day><Hour>14</Hour><Minute>17</Minute></PubMedPubDate><PubMedPubDate PubStatus="entrez"><Year>2025</Year><Month>9</Month><Day>30</Day><Hour>10</Hour><Minute>22</Minute></PubMedPubDate></History><PublicationStatus>ppublish</PublicationStatus><ArticleIdList><ArticleId IdType="pubmed">41026038</ArticleId><ArticleId IdType="doi">10.1080/03014460.2025.2558939</ArticleId></ArticleIdList></PubmedData></PubmedArticle></PubmedArticleSet>