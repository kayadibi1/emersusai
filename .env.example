NEXT_PUBLIC_SUPABASE_URL=https://supabase.YOUR_DOMAIN
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SELF_HOSTED_ANON_KEY
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=YOUR_SELF_HOSTED_ANON_KEY
SUPABASE_URL=https://supabase.YOUR_DOMAIN
SUPABASE_ANON_KEY=YOUR_SELF_HOSTED_ANON_KEY
SUPABASE_PUBLISHABLE_KEY=YOUR_SELF_HOSTED_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SELF_HOSTED_SERVICE_ROLE_KEY
RESEND_API_KEY=re_xxxxxxxxx
RESEND_FROM_EMAIL=onboarding@resend.dev
# Optional Resend hosted template ids. If set, the app sends these emails
# through Resend account templates with the listed variable payloads.
RESEND_TEMPLATE_WAITLIST_CONFIRM_ID=
RESEND_TEMPLATE_WAITLIST_CONFIRMED_ALERT_ID=
RESEND_TEMPLATE_CONTACT_ALERT_ID=
RESEND_TEMPLATE_SIGNUP_ALERT_ID=
RESEND_TEMPLATE_ALERT_ID=
OPENAI_API_KEY=sk-xxxxxxxx
OPENAI_EMERSUS_MODEL=gpt-5
OPENAI_EMERSUS_WEB_CONTEXT=medium
EMERSUS_EVIDENCE_TABLE=knowledge_documents
EMERSUS_EVIDENCE_RPC=match_knowledge_documents
EMERSUS_EVIDENCE_LIMIT=6
# Mapbox public token (URL-restricted to emersus.ai/*) used for share card route maps
MAPBOX_PUBLIC_TOKEN=pk.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Semantic Scholar Graph API key (for scripts/backfill-semantic-scholar.js).
# Unset → anonymous ~100 req/5min tier, 3500ms pause between batches.
# Set   → 1 req/sec authenticated tier, 1100ms pause. Sent as x-api-key header.
SEMANTIC_SCHOLAR_API_KEY=

# --- Multi-source ingestion (2026-04-12) ---
#
# MULTI_SOURCE_ENABLED gates the multi-source fanout in jobs/ingest-topic.js.
# When unset or not exactly "true", ingestion reverts to pubmed-only (the
# legacy phase 2 behavior). Set to "true" to enable fanout across every
# registered ingestion source (see scripts/sources/*.js).
MULTI_SOURCE_ENABLED=false

# Comma-separated list of source ids to exclude from fanout even when
# MULTI_SOURCE_ENABLED=true. Useful for temporarily disabling one source
# without disabling multi-source entirely.
INGEST_DISABLED_SOURCES=

# OpenAlex polite-pool email (optional but recommended). Passed as the
# mailto= query param on requests to api.openalex.org. Gives us priority
# in OpenAlex's polite pool (~10 req/sec).
OPENALEX_POLITE_EMAIL=

# Epistemonikos API key. Required for the Epistemonikos adapter. Obtain
# by emailing https://www.epistemonikos.org/en/about_us/contact_us
EPISTEMONIKOS_API_KEY=

# CORE API key. Required for the CORE adapter. Register at
# https://core.ac.uk/services/api (self-service, instant).
CORE_API_KEY=

# Memory subsystem kill switches (spec §9.8). All default FALSE — the
# user_memories table can exist in the DB without any runtime path being
# active. Flip to "true" (or "1") to enable each slice independently.
MEMORY_EXTRACTOR_ENABLED=false         # Phase 5 — auto-extractor
MEMORY_REMEMBER_FACT_ENABLED=false     # Phase 1 — explicit remember_fact tool
MEMORY_RECALL_ENABLED=false            # Phase 3 — recall_memory tool

