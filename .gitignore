# Environment files — never commit any .env or .env.* file
.env
.env.*
!.env.example
!infra/.env.template

# Self-hosted infrastructure — NEVER commit.
# infra/ contains the Hetzner deploy stack: docker-compose.yml, Caddyfile,
# Postgres tuning, generated Supabase JWT secret + service-role key, kong
# config, etc. Blanket-ignored so a stray `git add infra/` cannot leak
# secrets. The exception below allows the secret-free template to be
# explicitly tracked if you ever want to.
infra/*
!infra/.env.template
dumps/
.env.local.backup-managed

# Dependencies and build artifacts
node_modules/
dist/
build/
coverage/

# Backups and generated evidence-import caches
backups/
data/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Scratch / experimental work — never deploy
tmp/

# Claude Code per-machine settings (permissions, local config).
# Never belongs in the repo — each dev has their own grants.
.claude/
