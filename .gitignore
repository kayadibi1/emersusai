# Environment files — never commit any .env or .env.* file
.env
.env.*
!.env.example
!infra/.env.template

# Self-hosted Supabase secrets + migration dumps — NEVER commit.
# infra/.env.generated holds the JWT secret, anon key, and service-role
# key for the Hetzner-hosted Supabase instance.
infra/.env
infra/.env.generated
infra/.env.generated.warnings
dumps/
.env.local.backup-managed

# Dependencies and build artifacts
node_modules/
dist/
build/
coverage/

# Backups and generated evidence-import caches
backups/
data/

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Scratch / experimental work — never deploy
tmp/

# Claude Code per-machine settings (permissions, local config).
# Never belongs in the repo — each dev has their own grants.
.claude/
